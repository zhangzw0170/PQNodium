{
  "$schema": "https://raw.githubusercontent.com/nicedouble/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "PQNodium",
  "version": "0.1.0",
  "identifier": "com.pqnodium.app",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PQNodium",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": false
  }
}
